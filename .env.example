# Flex Rental Solutions credentials
# Your Flex login username (email)
FLEX_USERNAME=you@yourdomain.com
# Your Flex login password
FLEX_PASSWORD=your-flex-password
# The base URL for your Flex instance's API (this is the default for your URL)
FLEX_BASE_URL=https://clearlamp.flexrentalsolutions.com/f5/api/v2

# OpenAI API key — used for AI matching
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional tuning
# Model for AI matching (gpt-4o-mini is cheap and fast; gpt-4o for best accuracy)
OPENAI_MODEL=gpt-4o-mini
# How long (seconds) to cache the full inventory before re-fetching from Flex
INVENTORY_CACHE_TTL=300
# Confidence threshold (0-1) below which a match is flagged for your review
REVIEW_THRESHOLD=0.85
